# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different environment, you may want to ignore Pipfile.lock.
#   For details, see https://pipenv.pypa.io/en/latest/advanced/#pipfile-vs-pipfilelock
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains specific versions of dependencies
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains specific versions of dependencies
#pdm.lock
#   maintaining shared embeddable python runtime
.pdm-python
.pdm-build/

# PEP 582; dependency directory created by pdm when   shared-backend is used
__pypackages__/

